# Este archivo sí se sube a GitHub.
# El .env real NO se sube.

# Base central del sistema
DATABASE_URL=postgresql://USUARIO:CONTRASENA@HOST:PUERTO/NOMBRE_BD

# Usuario administrador de PostgreSQL para crear BD por empresa
DB_ADMIN_HOST=HOST
DB_ADMIN_PORT=5432
DB_ADMIN_USER=USUARIO_ADMIN
DB_ADMIN_PASSWORD=CONTRASENA_ADMIN
DB_ADMIN_DATABASE=postgres

SECRET_KEY=CAMBIAR_EN_PRODUCCION

PASSWORD_RESET_SALT=recuperacion-contrasena
PASSWORD_RESET_EMPRESA_SALT=recuperacion-contrasena-empresa

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=correo_del_sistema@gmail.com
SMTP_PASSWORD=contrasena_de_aplicacion
SMTP_FROM=Sistema Multiempresa <correo_del_sistema@gmail.com>

RESET_PASSWORD_FRONTEND_URL=http://localhost:4200/restablecer-contrasena
RESET_PASSWORD_EMPRESA_FRONTEND_URL=http://localhost:4200/empresa/restablecer-contrasena

DEBUG_RETURN_RESET_LINK=false
DEBUG_SKIP_EMAIL=false

GEMINI_API_KEY=TU_API_KEY_DE_GEMINI
GEMINI_MODEL=gemini-2.5-flash

WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

FIREBASE_CREDENTIALS_PATH=backend/firebase-service-account.json
FIREBASE_PROJECT_ID=TU_PROJECT_ID_FIREBASE